{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pre-commit: all files",
      "type": "shell",
      "command": "uv run pre-commit run --all-files",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "ruff: format check",
      "type": "shell",
      "command": "uv run ruff format --check .",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "ruff: check",
      "type": "shell",
      "command": "uv run ruff check .",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "ty: check",
      "type": "shell",
      "command": "uv run ty check",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "pytest",
      "type": "shell",
      "command": "uv run pytest",
      "group": "test",
      "problemMatcher": []
    }
  ]
}
